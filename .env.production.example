APP_ENV=production
LOG_LEVEL=INFO

API_DOMAIN=api.example.com
FRONTEND_ORIGIN=https://your-project.vercel.app
# BACKEND_API_URL is read by frontend/next.config.ts to proxy /api/* → backend.
# Must be set as a Vercel environment variable (Build & Runtime → BACKEND_API_URL).
# Example: https://api.example.com  (no trailing slash)
BACKEND_API_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app
TRUSTED_HOSTS=api.example.com
ENABLE_BEARER_TOKEN_AUTH=false
TRUST_X_FORWARDED_FOR=false
TRUSTED_PROXY_IPS=

POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg2://postgres:replace-with-a-strong-database-password@db:5432/ag_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

JWT_SECRET=replace-with-a-32-character-minimum-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_COOKIE_NAME=agis_session
SESSION_COOKIE_SAMESITE=none
CSRF_COOKIE_NAME=agis_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app

WORKOS_API_KEY=sk_live_replace_me
WORKOS_CLIENT_ID=client_replace_me
WORKOS_COOKIE_PASSWORD=replace-with-a-32-character-minimum-secret
# WorkOS must redirect back through the Vercel frontend /api proxy so the
# session cookie is set on the Vercel origin (same origin as the browser).
# Format: https://<your-vercel-domain>/api/auth/callback
WORKOS_REDIRECT_URI=https://your-project.vercel.app/api/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=https://your-project.vercel.app/
FOUNDER_ADMIN_EMAIL=founder@example.com

LLM_PROVIDER=aicredits
AICREDITS_BASE_URL=https://api.aicredits.in/v1
LLM_ENDPOINT=https://api.aicredits.in/v1/chat/completions
LLM_MODEL_NAME=openai/gpt-4o-mini
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.0
LLM_JSON_MODE=true
LLM_PAYLOAD_MODE=full
LLM_DISABLE_LIVE_CALLS=false

AICREDITS_GENERATION_API_KEY=
AICREDITS_GENERATION_MODEL_PRIMARY=openai/gpt-4o-mini
AICREDITS_GENERATION_MODEL_FALLBACK=openai/gpt-4.1-mini
AICREDITS_GENERATION_MAX_RETRIES=2
AICREDITS_GENERATION_BACKOFF_SECONDS=1
AICREDITS_GENERATION_MAX_CONCURRENCY=3
AICREDITS_GENERATION_MAX_ACTIVE_JOBS=3
AICREDITS_GENERATION_MAX_TOKENS=1600

AICREDITS_REPORT_CHAT_API_KEY=
AICREDITS_REPORT_CHAT_MODEL_PRIMARY=openai/gpt-4o-mini
AICREDITS_REPORT_CHAT_MODEL_FALLBACK=openai/gpt-4.1-mini
AICREDITS_REPORT_CHAT_MAX_RETRIES=3
AICREDITS_REPORT_CHAT_BACKOFF_SECONDS=1
AICREDITS_REPORT_CHAT_MAX_CONCURRENCY=2
AICREDITS_REPORT_CHAT_MAX_TOKENS=350
AICREDITS_REPORT_CHAT_PER_USER_LIMIT=12
AICREDITS_REPORT_CHAT_WINDOW_SECONDS=60
AICREDITS_REPORT_CHAT_MAX_ACTIVE_PER_USER=1

AICREDITS_INTERVIEW_REFINEMENT_API_KEY=
AICREDITS_INTERVIEW_REFINEMENT_MODEL_PRIMARY=openai/gpt-4o-mini
AICREDITS_INTERVIEW_REFINEMENT_MODEL_FALLBACK=openai/gpt-4.1-mini
AICREDITS_INTERVIEW_REFINEMENT_MAX_RETRIES=2
AICREDITS_INTERVIEW_REFINEMENT_BACKOFF_SECONDS=1
AICREDITS_INTERVIEW_REFINEMENT_MAX_CONCURRENCY=2
AICREDITS_INTERVIEW_REFINEMENT_MAX_TOKENS=900
AICREDITS_INTERVIEW_REFINEMENT_PER_USER_LIMIT=16
AICREDITS_INTERVIEW_REFINEMENT_WINDOW_SECONDS=60

REPORT_CHAT_MAX_QUESTION_CHARS=500
REPORT_CHAT_MAX_QUESTION_WORDS=80
INTERVIEW_REFINEMENT_MAX_TEXT_CHARS=4000
INTERVIEW_REFINEMENT_MAX_INSTRUCTION_CHARS=200

BRAINTRUST_API_KEY=

UPLOAD_DIRECTORY=/app/uploads
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-with-a-minio-access-key
MINIO_SECRET_KEY=replace-with-a-minio-secret-key
MINIO_BUCKET=ag-assets
# MinIO runs on plain HTTP inside Docker (see docker-compose.prod.yml).
# Set MINIO_SECURE=false for the internal Docker network connection.
# Only set to true if you add real TLS termination in front of MinIO.
MINIO_SECURE=false
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=agis
REDIS_CONNECT_TIMEOUT_SECONDS=2
MAX_UPLOAD_SIZE_MB=10
MAX_PROFILE_IMAGE_SIZE_MB=5

# NOTE: docker-compose.prod.yml always starts a dedicated worker container
# (python -m app.worker). That worker process IS your background processing;
# this flag only controls whether the API process itself also runs workers.
# Leave this false (recommended): let the dedicated worker container handle all jobs.
ENABLE_BACKGROUND_WORKERS=false
PROCESSING_WORKER_POLL_SECONDS=2
PROCESSING_JOB_MAX_ATTEMPTS=3
PROCESSING_JOB_BACKOFF_SECONDS=5
PROCESSING_JOB_STALE_AFTER_SECONDS=300

DEV_BOOTSTRAP_ADMIN=false
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
DEV_ADMIN_NAME=
PARSER_ENGINE_VERSION=v2
