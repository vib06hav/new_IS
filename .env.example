AICREDITS_GENERATION_MAX_ACTIVE_JOBS=3
AICREDITS_GENERATION_MAX_TOKENS=1600

AICREDITS_REPORT_CHAT_API_KEY=
AICREDITS_REPORT_CHAT_MODEL_PRIMARY=openai/gpt-4o-mini
