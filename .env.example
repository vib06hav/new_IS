DATABASE_URL=postgresql+psycopg2://postgres:postgres_password@db:5432/ag_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
JWT_SECRET=<set-a-strong-random-secret-at-least-32-characters-long>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_COOKIE_NAME=agis_session
SESSION_COOKIE_SAMESITE=lax
CSRF_COOKIE_NAME=agis_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TRUSTED_ORIGINS=
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://ollama:11434/api/generate
LLM_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free
LLM_API_KEY=<your-llm-api-key>
BRAINTRUST_API_KEY=<your-braintrust-api-key>
LLM_TIMEOUT_SECONDS=60
LLM_OLLAMA_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.0
LLM_JSON_MODE=true
LLM_PAYLOAD_MODE=full
LLM_KEEP_ALIVE=10m
LLM_LOAD_WAIT_TIMEOUT_SECONDS=120
LLM_LOAD_POLL_INTERVAL_SECONDS=5
UPLOAD_DIRECTORY=/app/uploads
MAX_UPLOAD_SIZE_MB=10
APP_ENV=development
LOG_LEVEL=DEBUG
DEV_BOOTSTRAP_ADMIN=false
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
DEV_ADMIN_NAME=
LLM_DISABLE_LIVE_CALLS=false
