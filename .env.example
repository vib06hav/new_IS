LLM_MODEL_NAME=openai/gpt-4o-mini
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.0
LLM_JSON_MODE=true
LLM_PAYLOAD_MODE=full
LLM_DISABLE_LIVE_CALLS=false

AICREDITS_GENERATION_API_KEY=
